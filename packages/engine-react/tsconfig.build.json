{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@/*": ["./src/*"],
      "@guardians/engine-core": ["../engine-core/src/index.ts"],
      "@guardians/engine-assets/*": ["../engine-assets/src/*"]
    }
  },
  "references": [{ "path": "../engine-core" }]
}
